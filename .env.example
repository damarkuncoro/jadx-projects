# DexForge Build Configuration
# Copy this file to .env and adjust values as needed

# Version string for the build (default: "dev")
# JADX_VERSION=1.5.8

# Java toolchain version for compilation (default: null = use current JDK)
# Must be >= 11
# JADX_BUILD_JAVA_VERSION=21

# ErrorProne checks level: off, warn, error (default: off)
# Requires Java 21+ when set to warn or error
# JADX_BUILD_CHECKS_MODE=off
